# Get a key at https://aistudio.google.com/apikey and paste it below
GEMINI_API_KEY=

# Optional overrides
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_TEXT_MODEL=gemini-flash-latest
PORT=3000

# Optional: use OpenAI's latest vision model for the image-reasoning step.
# Get a key at https://platform.openai.com/api-keys. Gemini is the fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
OPENAI_REASONING_EFFORT=low

OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
